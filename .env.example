# ==============================================================================
# SUPABASE CONFIGURATION
# ==============================================================================
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ==============================================================================
# SPOONASSIST — KROGER LIVE PRICES (Tier 1)
# ==============================================================================
# Register a free app at https://developer.kroger.com to get these.
# When set, live Kroger prices replace USDA baselines as the primary source.
# Falls through gracefully to USDA baselines for ZIPs with no nearby Kroger store.
# KROGER_CLIENT_ID=your_kroger_client_id_here
# KROGER_CLIENT_SECRET=your_kroger_client_secret_here

# ==============================================================================
# SPOONASSIST — GOOGLE PLACES STORE MATCHING
# ==============================================================================
# Get an API key at https://console.cloud.google.com (enable "Places API (New)").
# When set, ZIPs outside Kroger's coverage are matched against real nearby
# grocery_store/supermarket locations via Nearby Search before showing the
# static UNIVERSAL_CHAINS/NJ_CHAINS estimates, instead of assuming every chain
# is everywhere. Pricing for matched chains remains multiplier-based.
# GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# ==============================================================================
# SPOONASSIST — INSTACART INTEGRATION
# ==============================================================================
# Instacart Developer Platform key (required for "Shop on Instacart" button).
# Key must be approved by Instacart before it becomes active.
# INSTACART_API_KEY=keys.your_key_here
#
# Impact affiliate partner ID — appended to shopping list URLs for commission tracking.
# Get this from your Impact dashboard after joining the Instacart affiliate program.
# INSTACART_IMPACT_PARTNER_ID=your_impact_partner_id_here
#
# Optional override for the Instacart Connect API base URL. By default this is
# chosen from NODE_ENV (dev/sandbox vs production). Set this to pin a deployment
# to the sandbox API (https://connect.dev.instacart.tools) or production API
# (https://connect.instacart.com) regardless of NODE_ENV — useful while a
# production deployment is still under IDP review.
# INSTACART_API_BASE_URL=https://connect.dev.instacart.tools

# ==============================================================================
# STRIPE CONFIGURATION
# ==============================================================================
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ==============================================================================
# SITE SETTINGS
# ==============================================================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ==============================================================================
# PRODUCTION SETTINGS (uncomment and configure for production)
# ==============================================================================
# NEXT_PUBLIC_SITE_URL=https://yourdomain.com
# NODE_ENV=production

# ==============================================================================
# ANALYTICS (Optional - Create .env.local for these)
# ==============================================================================
# These variables should be added to .env.local (not committed to git)
# They are exposed to the browser and must be prefixed with NEXT_PUBLIC_
#
# PostHog — behavioral analytics & session recording (https://posthog.com)
# Use the same Project API Key for both variables.
# NEXT_PUBLIC_POSTHOG_KEY is used by posthog-js in the browser.
# POSTHOG_API_KEY is used by the server-side REST capture (e.g. Stripe webhook).
# NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_project_api_key_here
# POSTHOG_API_KEY=phc_your_posthog_project_api_key_here
#
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=seedandspoon.org
# NEXT_PUBLIC_GA4_ID=G-GQH6B8S4CY
# NEXT_PUBLIC_META_PIXEL_ID=your_meta_pixel_id_here
# NEXT_PUBLIC_TIKTOK_PIXEL_ID=your_tiktok_pixel_id_here
# NEXT_PUBLIC_SNAP_PIXEL_ID=your_snap_pixel_id_here
# NEXT_PUBLIC_PINTEREST_TAG_ID=your_pinterest_tag_id_here
# NEXT_PUBLIC_METRICOOL_HASH=your_metricool_hash_here
